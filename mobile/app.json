{
  "expo": {
    "name": "Trendy Travel",
    "slug": "trendy-travel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080d1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trendytravel.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080d1a"
      },
      "package": "com.trendytravel.app"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
